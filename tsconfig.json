{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".vercel/output/functions",
    "rootDir": ".",
    "resolveJsonModule": true,
    "noEmit": false
  },
  "include": ["api/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
